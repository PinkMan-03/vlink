// libvlink-defaults
cc_defaults {
    name: "libvlink-defaults",
    cppflags: [
        "-fexceptions",
        "-Wno-non-virtual-dtor",
        "-Wno-unknown-pragmas",
        "-Wno-implicit-fallthrough",
        "-Wno-unused-parameter",
        "-fvisibility=hidden",
    ],
    cpp_std: "c++17",
}

// libvlink
cc_library_shared {
    name: "libvlink",
    defaults: [
        "libvlink-defaults",
    ],
    // vendor_available: true,
    srcs: [
        "src/base/*.cc",
        "src/extension/*.cc",
        "src/impl/*.cc",
        "src/private/*.cc",
        "src/zerocopy/*.cc",
    ],
    local_include_dirs: [
        "include",
        "include/vlink",
        "thirdparty/lzav/include",
        "thirdparty/json/include",
        "thirdparty/mcap/include",
    ],
    export_include_dirs: [
        "include",
    ],
    shared_libs: [
        "liblog",
        "libcrypto",
        "libsqlite",
    ],
    static_libs: [
        "libc++fs",
    ],
    cppflags: [
        "-DVLINK_LIBRARY",
        "-DVLINK_ENABLE_LOG_NAT",
        "-DVLINK_ENABLE_SECURITY",
        "-DVLINK_ENABLE_SQLITE",
    ],
}

// libvlink-intra
cc_library_shared {
    name: "libvlink-intra",
    defaults: [
        "libvlink-defaults",
    ],
    // vendor_available: true,
    srcs: [
        "modules/intra/*.cc",
    ],
    local_include_dirs: [
        "modules/intra",
        "include/vlink",
    ],
    cppflags: [
        "-DVLINK_LIBRARY",
        "-DVLINK_SUPPORT_INTRA",
    ],
    shared_libs: [
        "libvlink",
    ],
}

// libvlink-dds
cc_library_shared {
    name: "libvlink-dds",
    defaults: [
        "libvlink-defaults",
    ],
    // vendor_available: true,
    srcs: [
        "modules/dds/*.cc",
        "modules/dds/builtin/2_x/*.cxx",
    ],
    local_include_dirs: [
        "modules/dds",
        "modules/dds/builtin",
        "include/vlink",
    ],
    cppflags: [
        "-DVLINK_LIBRARY",
        "-DVLINK_SUPPORT_DDS",
    ],
    shared_libs: [
        "libvlink",
        "libfastrtps",
        "libfastcdr",
    ],
}

// libvlink-ddsc
cc_library_shared {
    name: "libvlink-ddsc",
    defaults: [
        "libvlink-defaults",
    ],
    // vendor_available: true,
    srcs: [
        "modules/ddsc/*.cc",
        "modules/ddsc/builtin/*.c",
    ],
    local_include_dirs: [
        "modules/ddsc",
        "modules/ddsc/builtin",
        "include/vlink",
    ],
    cppflags: [
        "-DVLINK_LIBRARY",
        "-DVLINK_SUPPORT_DDSC",
    ],
    shared_libs: [
        "libvlink",
        "libcyclonedds",
    ],
}

// libvlink-c_api
cc_library_shared {
    name: "libvlink-c_api",
    defaults: [
        "libvlink-defaults",
    ],
    // vendor_available: true,
    srcs: [
        "c_api/*.cc",
    ],
    local_include_dirs: [
        "include/vlink",
    ],
    cppflags: [
        "-DVLINK_C_API_LIBRARY",
        "-DVLINK_ENABLE_C_INTERFACE",
        "-DVLINK_SUPPORT_INTRA",
        "-DVLINK_SUPPORT_DDS",
        "-DVLINK_SUPPORT_DDSC",
    ],
    shared_libs: [
        "libvlink",
        "libvlink-intra",
        "libvlink-dds",
        "libvlink-ddsc",
    ],
}

// libvlink-proxy_api
cc_library_shared {
    name: "libvlink-proxy_api",
    defaults: [
        "libvlink-defaults",
    ],
    rtti: true,
    // vendor_available: true,
    srcs: [
        "proxy/proxy_api/*.cc",
    ],
    local_include_dirs: [
        "proxy",
        "include/vlink",
        "thirdparty/bitsery/include",
    ],
    cppflags: [
        "-DVLINK_ENABLE_PROXY",
        "-DVLINK_PROXY_API_LIBRARY",
        "-DVLINK_SUPPORT_INTRA",
        "-DVLINK_SUPPORT_DDS",
        "-DVLINK_SUPPORT_DDSC",
    ],
    shared_libs: [
        "libvlink",
        "libvlink-intra",
        "libvlink-dds",
        "libvlink-ddsc",
    ],
}

