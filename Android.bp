// vlink-proxy
cc_binary {
    name: "vlink-proxy",
    defaults: [
        "libvlink-defaults",
    ],
    rtti: true,
    srcs: [
        "proxy/*.cc",
    ],
    local_include_dirs: [
        "proxy",
        "include/vlink",
        "thirdparty/argparse/include",
    ],
    cppflags: [
        "-DVLINK_ENABLE_PROXY",
        "-DVLINK_SUPPORT_INTRA",
        "-DVLINK_SUPPORT_DDS",
        "-DVLINK_SUPPORT_DDSC",
    ],
    shared_libs: [
        "libvlink",
        "libvlink-intra",
        "libvlink-dds",
        "libvlink-ddsc",
        "libvlink-proxy_server",
    ],
}

