// vlink-test
cc_binary {
    name: "vlink-test",
    defaults: [
        "libvlink-defaults",
    ],
    srcs: [
        "test/*.cc",
        "test/base/*.cc",
        "test/idl/*.proto",
    ],
    local_include_dirs: [
        "test",
        "include/vlink",
        "thirdparty/doctest/include",
    ],
    cppflags: [
        "-DVLINK_ENABLE_SECURITY",
        "-DVLINK_ENABLE_SQLITE",
        "-DVLINK_SUPPORT_INTRA",
        "-DVLINK_SUPPORT_DDS",
        "-DVLINK_SUPPORT_DDSC",
        "-DVLINK_TEST_SUPPORT_SECURITY",
        "-DVLINK_TEST_SUPPORT_PROTOBUF",
    ],
    shared_libs: [
        "libvlink",
        "libvlink-intra",
        "libvlink-dds",
        "libvlink-ddsc",
        "libcrypto",
        "libprotobuf-cpp-lite",
    ],
    proto: {type: "lite"},
}
