set(@PROJECT_NAME@_FIND_ARGS)
if(@PROJECT_NAME@_FIND_REQUIRED)
  list(APPEND @PROJECT_NAME@_FIND_ARGS REQUIRED)
endif()
if(@PROJECT_NAME@_FIND_QUIETLY)
  list(APPEND @PROJECT_NAME@_FIND_ARGS QUIET)
endif()

set(VLINK_DEFAULT_LIBRARIES @VLINK_DEFAULT_LIBRARIES@)
set(VLINK_INSTALL_CONFIG_DIR @INSTALL_CONFIG_DIR@)
foreach(component ${@PROJECT_NAME@_FIND_COMPONENTS})
  string(TOLOWER "${component}" component_lower)
  if(${component_lower} IN_LIST VLINK_COMPONENTS)
    continue()
  endif()
  list(APPEND VLINK_COMPONENTS ${component_lower})
  if(${component_lower} STREQUAL "all")
    foreach(library ${VLINK_DEFAULT_LIBRARIES})
      string(REPLACE "@PROJECT_NAMESPACE@" "" real_component "${library}")
      if(NOT TARGET @PROJECT_NAMESPACE@${real_component})
        find_package(@PROJECT_NAME@-${real_component} CONFIG QUIET)
      endif()
      if(TARGET @PROJECT_NAMESPACE@${real_component})
        set(@PROJECT_NAME@_${real_component}_FOUND TRUE)
      else()
        set(@PROJECT_NAME@_${real_component}_FOUND FALSE)
        if(${@PROJECT_NAME@_FIND_REQUIRED})
          message(WARNING "@PROJECT_NAME@: Required component '${real_component}' not found")
        endif()
      endif()
    endforeach()
    set(@PROJECT_NAME@_ALL_FOUND TRUE)
  else()
    if(NOT TARGET @PROJECT_NAMESPACE@${component_lower})
      find_package(@PROJECT_NAME@-${component_lower} CONFIG QUIET)
    endif()
    if(TARGET @PROJECT_NAMESPACE@${component_lower})
      set(@PROJECT_NAME@_${component}_FOUND TRUE)
      set(@PROJECT_NAME@_${component_lower}_FOUND TRUE)
    else()
      set(@PROJECT_NAME@_${component}_FOUND FALSE)
      set(@PROJECT_NAME@_${component_lower}_FOUND FALSE)
      if(${@PROJECT_NAME@_FIND_REQUIRED})
        message(FATAL_ERROR "@PROJECT_NAME@: Required component '${component}' not found")
      endif()
    endif()
  endif()
endforeach()
list(REMOVE_DUPLICATES VLINK_COMPONENTS)
list(REMOVE_DUPLICATES VLINK_LIBRARIES)
set(VLINK_NO_INTRA_LIBRARIES ${VLINK_LIBRARIES})
list(REMOVE_ITEM VLINK_NO_INTRA_LIBRARIES "@PROJECT_NAMESPACE@intra")
if(NOT TARGET @PROJECT_NAMESPACE@@PROJECT_NAME@)
  find_package(Threads ${@PROJECT_NAME@_FIND_ARGS})
  include(${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@-targets.cmake)
endif()
if(NOT TARGET @PROJECT_NAMESPACE@all)
  add_library(@PROJECT_NAMESPACE@all INTERFACE IMPORTED GLOBAL)
endif()
set_target_properties(
  @PROJECT_NAMESPACE@all PROPERTIES INTERFACE_LINK_LIBRARIES "@PROJECT_NAMESPACE@@PROJECT_NAME@;${VLINK_LIBRARIES}"
)

if(NOT _VLINK_FUNCTIONS_INCLUDED)
  set(_VLINK_FUNCTIONS_INCLUDED TRUE)
  file(GLOB _FUNCTION_FILES CONFIGURE_DEPENDS "${CMAKE_CURRENT_LIST_DIR}/functions/*.cmake")
  foreach(file ${_FUNCTION_FILES})
    include(${file})
  endforeach()
  unset(_FUNCTION_FILES)
endif()

unset(@PROJECT_NAME@_FIND_ARGS)
