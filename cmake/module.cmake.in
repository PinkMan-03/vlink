if(TARGET @PROJECT_NAMESPACE@@PROJECT_NAME@)
  return()
endif()

if("@VLINK_MODULE_NAME@" STREQUAL "")
  include(${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@-targets.cmake)
  return()
endif()

set(@PROJECT_NAME@_FIND_ARGS)
if(@PROJECT_NAME@_FIND_REQUIRED)
  list(APPEND @PROJECT_NAME@_FIND_ARGS REQUIRED)
endif()
if(@PROJECT_NAME@_FIND_QUIETLY)
  list(APPEND @PROJECT_NAME@_FIND_ARGS QUIET)
endif()

if(NOT "@PROJECT_NAMESPACE@@VLINK_MODULE_NAME@" IN_LIST VLINK_LIBRARIES)
  list(APPEND VLINK_LIBRARIES "@PROJECT_NAMESPACE@@VLINK_MODULE_NAME@")
endif()
set(_VLINK_MODULE_IMPORT_ALL @VLINK_MODULE_IMPORT_ALL@)
if(_VLINK_MODULE_IMPORT_ALL)
  if(NOT @CMAKE_PROJECT_NAME@_ALL_FOUND)
    find_package(@CMAKE_PROJECT_NAME@ COMPONENTS all CONFIG ${@PROJECT_NAME@_FIND_ARGS})
  endif()
else()
  if(NOT @CMAKE_PROJECT_NAME@_FOUND)
    find_package(@CMAKE_PROJECT_NAME@ CONFIG ${@PROJECT_NAME@_FIND_ARGS})
  endif()
endif()
unset(_VLINK_MODULE_IMPORT_ALL)
if(vlink_FOUND)
  include(${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@-targets.cmake)
  if(NOT TARGET @PROJECT_NAMESPACE@@VLINK_MODULE_NAME@)
    add_library(@PROJECT_NAMESPACE@@VLINK_MODULE_NAME@ INTERFACE IMPORTED GLOBAL)
    set_target_properties(
      @PROJECT_NAMESPACE@@VLINK_MODULE_NAME@
      PROPERTIES INTERFACE_LINK_LIBRARIES "@PROJECT_NAMESPACE@@CMAKE_PROJECT_NAME@;@PROJECT_NAMESPACE@@PROJECT_NAME@"
    )
  endif()
endif()

unset(@PROJECT_NAME@_FIND_ARGS)
