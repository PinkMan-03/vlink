  <diagram id="bytes-ownership" name="Bytes Ownership Modes">
    <mxGraphModel dx="1000" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Bytes Ownership Modes" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=22;fontStyle=1;fontColor=#263238;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="920" height="32" as="geometry" />
        </mxCell>
        <mxCell id="sub" value="Five factory methods, three ownership semantics" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=13;fontStyle=2;fontColor=#78909c;" vertex="1" parent="1">
          <mxGeometry x="40" y="54" width="920" height="22" as="geometry" />
        </mxCell>

        <!-- Center -->
        <mxCell id="center" value="&lt;b style=&quot;font-size:16px;&quot;&gt;Bytes&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;&quot;&gt;128 B object &#183; 96 B SBO + optional heap&lt;br/&gt;5 factory methods select ownership semantics&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eceff1;strokeColor=#424242;strokeWidth=1.8;fontSize=13;fontColor=#263238;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="240" width="320" height="90" as="geometry" />
        </mxCell>

        <!-- Top row: 3 cards -->
        <mxCell id="c1" value="&lt;b style=&quot;font-family:Courier New;&quot;&gt;Bytes::create(n)&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;&quot;&gt;Owns memory &#183; deep copy on copy&lt;br/&gt;Fresh allocation (SBO ≤ 96 B, heap otherwise)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;strokeWidth=1.5;fontSize=12;fontColor=#0d47a1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="96" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="c2" value="&lt;b style=&quot;font-family:Courier New;&quot;&gt;Bytes::shallow_copy(ptr, size)&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;&quot;&gt;Non-owning &#183; pointer alias&lt;br/&gt;Zero-copy wrap of external buffer&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;strokeWidth=1.5;fontSize=12;fontColor=#1b5e20;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="96" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="c3" value="&lt;b style=&quot;font-family:Courier New;&quot;&gt;Bytes::deep_copy(ptr, size)&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;&quot;&gt;Owns memory &#183; deep copy on copy&lt;br/&gt;Owned copy of external buffer&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2f1;strokeColor=#00838f;strokeWidth=1.5;fontSize=12;fontColor=#004d40;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="96" width="280" height="100" as="geometry" />
        </mxCell>

        <!-- Bottom row: 2 cards -->
        <mxCell id="c4" value="&lt;b style=&quot;font-family:Courier New;&quot;&gt;Bytes::loan_internal(ptr, size)&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;&quot;&gt;Non-owning (loaned) &#183; pointer alias&lt;br/&gt;Transport loan buffer (shm/shm2/zenoh SHM)&lt;br/&gt;Must NOT be freed by VLink&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#ef6c00;strokeWidth=1.5;fontSize=12;fontColor=#e65100;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="140" y="390" width="310" height="110" as="geometry" />
        </mxCell>
        <mxCell id="c5" value="&lt;b style=&quot;font-family:Courier New;&quot;&gt;Bytes::shallow_copy_ptr(ptr)&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;&quot;&gt;Non-owning &#183; pointer alias (size == 0)&lt;br/&gt;Wrap opaque pointer&lt;br/&gt;Loan-return &#183; is_ptr() scenarios&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#8e24aa;strokeWidth=1.5;fontSize=12;fontColor=#4a148c;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="550" y="390" width="310" height="110" as="geometry" />
        </mxCell>

