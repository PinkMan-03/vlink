          <mxGeometry x="780" y="100" width="280" height="6" as="geometry" />
        </mxCell>
        <mxCell id="readertitle" value="Reader side &#160;(any thread)" style="text;html=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=14;fontStyle=1;fontColor=#0d47a1;" vertex="1" parent="1">
