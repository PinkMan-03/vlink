        </mxCell>
        <mxCell id="state_cancel" value="bool cancelled  (one-shot, mutex-protected)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eceff1;strokeColor=#90a4ae;strokeWidth=1;fontSize=11;fontFamily=Courier New;fontColor=#37474f;arcSize=8;" vertex="1" parent="1">
