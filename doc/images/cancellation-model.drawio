        <mxCell id="state_next" value="size_t next_id  (mutex-protected)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eceff1;strokeColor=#90a4ae;strokeWidth=1;fontSize=11;fontFamily=Courier New;fontColor=#37474f;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="400" y="280" width="300" height="32" as="geometry" />
        </mxCell>
        <mxCell id="state_cbmap" value="unordered_map&lt;id, MoveFunction&lt;void()&gt;&gt; callbacks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eceff1;strokeColor=#90a4ae;strokeWidth=1;fontSize=11;fontFamily=Courier New;fontColor=#37474f;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="400" y="320" width="300" height="32" as="geometry" />
        </mxCell>
        <mxCell id="state_note" value="On request_cancel(): swap callbacks out, release mutex,&#10;then invoke each one on the calling thread." style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=11;fontFamily=Verdana;fontStyle=2;fontColor=#455a64;" vertex="1" parent="1">
          <mxGeometry x="400" y="365" width="300" height="60" as="geometry" />
        </mxCell>

        <mxCell id="readerbg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#90caf9;strokeWidth=1.5;arcSize=4;gradientColor=#e3f2fd;gradientDirection=north;" vertex="1" parent="1">
