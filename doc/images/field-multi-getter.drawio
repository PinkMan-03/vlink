        <!-- Cache -> Getter A/B/C -->
        <mxCell id="e_ga" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;endFill=1;html=1;strokeWidth=2.2;strokeColor=#ef6c00;exitX=1;exitY=0.3;entryX=0;entryY=0.5;" edge="1" parent="1" source="cache" target="ga">
          <mxGeometry relative="1" as="geometry" />
