        <!-- Legend / note -->
        <mxCell id="notebg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#ffcc80;strokeWidth=1.2;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="820" height="40" as="geometry" />
        </mxCell>
        <mxCell id="notetxt" value="Cardinality: N Setters &#8594; latest-value updates &#8594; N Getters (N : N) &#183; late-join is backend-dependent" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=12;fontStyle=1;fontColor=#e65100;" vertex="1" parent="1">
