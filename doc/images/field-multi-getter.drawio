        <mxCell id="e_gb" value="&lt;b&gt;latest&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=classic;endFill=1;html=1;strokeWidth=2.2;strokeColor=#ef6c00;fontSize=11;fontStyle=1;fontColor=#bf360c;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="cache" target="gb">
