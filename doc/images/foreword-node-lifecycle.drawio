  <diagram id="foreword-node-lifecycle" name="Node Lifecycle">
    <mxGraphModel dx="900" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Node Lifecycle &#160;&#183;&#160; State Machine" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=20;fontStyle=1;fontColor=#263238;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="820" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Construct &#8594; init() &#8594; Running &#8594; deinit() &#8594; Destruct, with optional side transitions" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=12;fontStyle=2;fontColor=#78909c;" vertex="1" parent="1">
          <mxGeometry x="40" y="52" width="820" height="20" as="geometry" />
        </mxCell>

        <!-- Construct (gray) -->
        <mxCell id="s0" value="Construct" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eceff1;strokeColor=#546e7a;strokeWidth=1.5;fontSize=14;fontStyle=1;fontColor=#37474f;shadow=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="100" width="200" height="56" as="geometry" />
        </mxCell>

        <!-- init() (blue) -->
        <mxCell id="s1" value="init()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;strokeWidth=1.5;fontSize=14;fontStyle=1;fontFamily=Courier New;fontColor=#0d47a1;shadow=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="200" width="200" height="56" as="geometry" />
        </mxCell>

        <!-- Running (orange - state highlight) -->
        <mxCell id="s2" value="Running" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe082;strokeColor=#ef6c00;strokeWidth=1.8;fontSize=15;fontStyle=1;fontColor=#bf360c;shadow=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="300" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- deinit() (green) -->
        <mxCell id="s3" value="deinit()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;strokeWidth=1.5;fontSize=14;fontStyle=1;fontFamily=Courier New;fontColor=#1b5e20;shadow=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="404" width="200" height="56" as="geometry" />
        </mxCell>

        <!-- Destruct (gray) -->
        <mxCell id="s4" value="Destruct" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eceff1;strokeColor=#546e7a;strokeWidth=1.5;fontSize=14;fontStyle=1;fontColor=#37474f;shadow=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="504" width="200" height="56" as="geometry" />
        </mxCell>

        <!-- Pause/Resume side (left) -->
        <mxCell id="sL" value="Paused" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eceff1;strokeColor=#90a4ae;strokeWidth=1.3;fontSize=13;fontStyle=1;fontColor=#455a64;shadow=1;arcSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="90" y="302" width="160" height="56" as="geometry" />
        </mxCell>

        <!-- Interrupt side (right) -->
        <mxCell id="sR" value="Interrupted" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#c62828;strokeWidth=1.3;fontSize=13;fontStyle=1;fontColor=#b71c1c;shadow=1;arcSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="302" width="160" height="56" as="geometry" />
        </mxCell>

        <!-- Edges main chain -->
        <mxCell id="e01" value="construct" style="endArrow=classic;endFill=1;html=1;strokeWidth=2;strokeColor=#455a64;fontSize=11;fontStyle=2;fontColor=#455a64;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s0" target="s1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12" value="init() ok" style="endArrow=classic;endFill=1;html=1;strokeWidth=2;strokeColor=#455a64;fontSize=11;fontStyle=2;fontColor=#455a64;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s1" target="s2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e23" value="shutdown" style="endArrow=classic;endFill=1;html=1;strokeWidth=2;strokeColor=#455a64;fontSize=11;fontStyle=2;fontColor=#455a64;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s2" target="s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e34" value="destruct" style="endArrow=classic;endFill=1;html=1;strokeWidth=2;strokeColor=#455a64;fontSize=11;fontStyle=2;fontColor=#455a64;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s3" target="s4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Running -> Paused (suspend) -->
        <mxCell id="eL" value="suspend()" style="endArrow=classic;endFill=1;html=1;strokeWidth=2;strokeColor=#546e7a;fontSize=11;fontStyle=1;fontFamily=Courier New;fontColor=#455a64;labelBackgroundColor=#ffffff;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" parent="1" source="s2" target="sL">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Paused -> Running (resume) -->
        <mxCell id="eLb" value="resume()" style="endArrow=classic;endFill=1;html=1;strokeWidth=2;strokeColor=#546e7a;fontSize=11;fontStyle=1;fontFamily=Courier New;fontColor=#455a64;labelBackgroundColor=#ffffff;exitX=1;exitY=0.3;entryX=0;entryY=0.3;" edge="1" parent="1" source="sL" target="s2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Running -> Interrupted -->
        <mxCell id="eR" value="interrupt()" style="endArrow=classic;endFill=1;html=1;strokeWidth=2;strokeColor=#c62828;fontSize=11;fontStyle=1;fontFamily=Courier New;fontColor=#b71c1c;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="s2" target="sR">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Interrupted -> deinit -->
        <mxCell id="eRb" value="unblocks" style="endArrow=classic;endFill=1;html=1;strokeWidth=2;strokeColor=#c62828;fontSize=11;fontStyle=2;fontColor=#b71c1c;labelBackgroundColor=#ffffff;dashed=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=1;entryY=0.3;" edge="1" parent="1" source="sR" target="s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

