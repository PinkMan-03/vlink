<mxfile host="app.diagrams.net" modified="2026-04-23T00:00:00.000Z" agent="Claude" version="24.0.0" type="device">
  <diagram id="node-lifecycle" name="Node Lifecycle">
    <mxGraphModel dx="1000" dy="760" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="760" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Node Lifecycle &#8212; Construct to Destroy" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=20;fontStyle=1;fontColor=#263238;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="920" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Lifecycle is owned by the Node base &#160;&#183;&#160; Transitions are explicit and observable" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=12;fontStyle=2;fontColor=#78909c;" vertex="1" parent="1">
          <mxGeometry x="40" y="50" width="920" height="22" as="geometry" />
        </mxCell>

        <mxCell id="s1" value="&lt;b style=&quot;font-size:15px&quot;&gt;Construct&lt;/b&gt;&#10;&lt;span style=&quot;font-size:11px&quot;&gt;Node(url) or Node(conf)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eceff1;strokeColor=#607d8b;strokeWidth=1.5;fontSize=12;fontColor=#37474f;shadow=1;arcSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="100" width="400" height="80" as="geometry" />
        </mxCell>

        <mxCell id="a1" value="auto init / manual init()" style="endArrow=classic;endFill=1;html=1;strokeWidth=2.2;strokeColor=#455a64;fontSize=11;fontStyle=1;fontColor=#37474f;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="s1" target="s2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="s2" value="&lt;b style=&quot;font-size:15px&quot;&gt;Initializing&lt;/b&gt;&#10;&lt;span style=&quot;font-size:11px&quot;&gt;Load plugin, parse URL, create transport channel&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;strokeWidth=1.5;fontSize=12;fontColor=#0d47a1;shadow=1;arcSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="240" width="400" height="80" as="geometry" />
        </mxCell>

        <mxCell id="a2" value="init complete" style="endArrow=classic;endFill=1;html=1;strokeWidth=2.2;strokeColor=#1565c0;fontSize=11;fontStyle=1;fontColor=#0d47a1;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="s2" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="s3" value="&lt;b style=&quot;font-size:15px&quot;&gt;Ready&lt;/b&gt;&#10;&lt;span style=&quot;font-size:11px&quot;&gt;Can send and receive messages&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;strokeWidth=1.5;fontSize=12;fontColor=#1b5e20;shadow=1;arcSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="380" width="400" height="80" as="geometry" />
        </mxCell>

        <mxCell id="sl" value="&lt;span style=&quot;font-size:11px&quot;&gt;register callback&lt;br/&gt;listen() / on_request()&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#ef6c00;strokeWidth=1.5;fontSize=12;fontColor=#bf360c;shadow=1;arcSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="390" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="al" style="endArrow=classic;endFill=1;html=1;strokeWidth=2;strokeColor=#ef6c00;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s3" target="sl" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="sr" value="&lt;span style=&quot;font-size:11px&quot;&gt;data plane&lt;br/&gt;publish() / invoke() / set() / get()&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#ef6c00;strokeWidth=1.5;fontSize=12;fontColor=#bf360c;shadow=1;arcSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="740" y="390" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ar" style="endArrow=classic;endFill=1;html=1;strokeWidth=2;strokeColor=#ef6c00;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="s3" target="sr" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="a3" value="destruct / deinit()" style="endArrow=classic;endFill=1;html=1;strokeWidth=2.2;strokeColor=#c62828;fontSize=11;fontStyle=1;fontColor=#b71c1c;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="s3" target="s4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="s4" value="&lt;b style=&quot;font-size:15px&quot;&gt;Destroy&lt;/b&gt;&#10;&lt;span style=&quot;font-size:11px&quot;&gt;Release resources, unregister discovery, close transport&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#c62828;strokeWidth=1.5;fontSize=12;fontColor=#b71c1c;shadow=1;arcSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="520" width="400" height="80" as="geometry" />
        </mxCell>

        <mxCell id="footnote" value="Orange boxes are side-effects available only in the Ready state" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=10;fontStyle=2;fontColor=#546e7a;" vertex="1" parent="1">
