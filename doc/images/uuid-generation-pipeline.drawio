          <mxGeometry x="76" y="350" width="500" height="20" as="geometry" />
        </mxCell>

        <mxCell id="d_dist" value="&lt;b&gt;uniform_int_distribution&amp;lt;uint32_t&amp;gt;&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px;&quot;&gt;4 bytes per draw&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;strokeWidth=1.5;fontSize=13;fontColor=#0d47a1;shadow=1;" vertex="1" parent="1">
