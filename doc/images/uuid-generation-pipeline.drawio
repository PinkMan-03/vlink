        </mxCell>
        <mxCell id="d_shift" value="&lt;b&gt;byte extraction&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px;&quot;&gt;explicit shifts -- no reinterpret_cast&lt;br/&gt;LE/BE outputs identical given same seed&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;strokeWidth=1.5;fontSize=13;fontColor=#0d47a1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="390" width="380" height="80" as="geometry" />
        </mxCell>
        <mxCell id="d_buf" value="&lt;b&gt;buffer&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px;&quot;&gt;data[0..15] -- 128-bit payload&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;strokeWidth=1.5;fontSize=13;fontColor=#0d47a1;shadow=1;" vertex="1" parent="1">
