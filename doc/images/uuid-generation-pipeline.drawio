          <mxGeometry x="60" y="520" width="1160" height="150" as="geometry" />
        </mxCell>
        <mxCell id="rfc_lane_lbl" value="RFC 4122 v4 bit-pinning" style="text;html=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=11;fontStyle=2;fontColor=#6a1b9a;" vertex="1" parent="1">
          <mxGeometry x="76" y="530" width="400" height="20" as="geometry" />
        </mxCell>

        <mxCell id="r_ver" value="&lt;b&gt;version byte (octet 6)&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;font-family:monospace;&quot;&gt;data[6] = (data[6] &amp;amp; 0x0F) | 0x40&lt;/span&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px;&quot;&gt;forces high nibble = 0100 (v4)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#8e24aa;strokeWidth=1.5;fontSize=13;fontColor=#4a148c;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="570" width="420" height="90" as="geometry" />
        </mxCell>
        <mxCell id="r_var" value="&lt;b&gt;variant byte (octet 8)&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:11px;font-family:monospace;&quot;&gt;data[8] = (data[8] &amp;amp; 0x3F) | 0x80&lt;/span&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px;&quot;&gt;forces top two bits = 10 (RFC)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1bee7;strokeColor=#8e24aa;strokeWidth=1.5;fontSize=13;fontColor=#4a148c;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="570" width="420" height="90" as="geometry" />
        </mxCell>
        <mxCell id="r_uuid" value="&lt;b&gt;Uuid&lt;/b&gt;&lt;br/&gt;&lt;span style=&quot;font-size:10px;&quot;&gt;variant() == kRfc&lt;br/&gt;version() == kRandomBased&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;strokeWidth=2;fontSize=14;fontStyle=1;fontColor=#1b5e20;shadow=1;" vertex="1" parent="1">
