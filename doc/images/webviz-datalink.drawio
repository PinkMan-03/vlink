        <mxCell id="note2" value="Subscription Flow (Rerun)&#10;1. RerunServer auto-subscribes ALL URLs&#10;2. on_data() -&gt; find_all_mappings()&#10;3. convert_and_log() for each mapping&#10;4. log to Rerun SDK (gRPC stream)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=14;fillColor=#e3f2fd;strokeColor=#1565c0;fontSize=10;fontColor=#0d47a1;align=left;fontStyle=1;" vertex="1" parent="1">
