        <mxCell id="api_graph" value="GraphTask::register_status_callback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="800" y="410" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- ============= FRAME ALLOC ============= -->
