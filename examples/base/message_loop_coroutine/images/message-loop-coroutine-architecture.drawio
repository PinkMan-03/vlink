<mxfile host="app.diagrams.net" agent="vlink-example" version="24.0.0">
  <diagram name="MessageLoop+Coroutine" id="mlc-arch">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="780" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ============= USER LAYER ============= -->
        <mxCell id="usr_box" value="User Coroutine&#10;(Task&lt;T&gt; body)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="80" y="60" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- ============= AWAITERS ============= -->
        <mxCell id="aw_title" value="Awaiters (suspension points)" style="text;html=1;align=center;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="20" width="320" height="30" as="geometry" />
        </mxCell>
        <mxCell id="aw_schedule" value="schedule(loop, prio)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="380" y="60" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="aw_yield" value="yield(loop, prio)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="380" y="110" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="aw_delay" value="delay_ms(loop, n, prio)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="380" y="160" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="aw_future" value="await_future(loop, fut)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="540" y="60" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="aw_graph" value="await_graph(loop, g)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="540" y="110" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="aw_exec" value="exec(loop, cfg, fn)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="540" y="160" width="160" height="40" as="geometry" />
        </mxCell>

        <!-- ============= ORCHESTRATION ============= -->
        <mxCell id="orch_title" value="Orchestration" style="text;html=1;align=center;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="220" width="320" height="30" as="geometry" />
        </mxCell>
        <mxCell id="orch_all" value="when_all" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="380" y="260" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="orch_any" value="when_any" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="490" y="260" width="100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="orch_seq" value="sequence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="600" y="260" width="100" height="40" as="geometry" />
        </mxCell>

        <!-- ============= LOOP ============= -->
        <mxCell id="loop_box" value="MessageLoop&#10;(task queue + dispatcher thread)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="780" y="100" width="260" height="120" as="geometry" />
        </mxCell>

        <!-- ============= BACKING APIS ============= -->
        <mxCell id="api_title" value="Backing public MessageLoop / Timer / Schedule / GraphTask APIs" style="text;html=1;align=center;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="370" width="960" height="30" as="geometry" />
        </mxCell>
        <mxCell id="api_post" value="post_task(cb)&#10;post_task_with_priority(cb, prio)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="80" y="410" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="api_timer" value="Timer::call_once(loop, ms, cb, prio)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="320" y="410" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="api_sched" value="MessageLoop::exec_task(cfg, cb)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="560" y="410" width="220" height="60" as="geometry" />
