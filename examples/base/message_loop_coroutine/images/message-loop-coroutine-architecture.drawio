          <mxGeometry x="380" y="540" width="320" height="60" as="geometry" />
        </mxCell>

        <!-- ============= ARROWS ============= -->
        <mxCell id="e_user_aw" style="endArrow=classic;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="usr_box" target="aw_schedule">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_aw_loop_1" style="endArrow=classic;html=1;" edge="1" parent="1" source="aw_schedule" target="loop_box">
