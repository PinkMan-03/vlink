        <mxCell id="e_aw_loop_6" style="endArrow=classic;html=1;" edge="1" parent="1" source="aw_exec" target="loop_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_api_1" style="endArrow=classic;html=1;dashed=1;" edge="1" parent="1" source="aw_schedule" target="api_post">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_api_2" style="endArrow=classic;html=1;dashed=1;" edge="1" parent="1" source="aw_delay" target="api_timer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_api_3" style="endArrow=classic;html=1;dashed=1;" edge="1" parent="1" source="aw_exec" target="api_sched">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_api_4" style="endArrow=classic;html=1;dashed=1;" edge="1" parent="1" source="aw_graph" target="api_graph">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_pool_1" style="endArrow=classic;html=1;dashed=1;startArrow=classic;startFill=1;" edge="1" parent="1" source="usr_box" target="pool_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="resume_label" value="resume() ← lambda ← dispatcher" style="text;html=1;strokeColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="320" y="320" width="430" height="30" as="geometry" />
        </mxCell>
        <mxCell id="e_resume" style="endArrow=classic;html=1;" edge="1" parent="1" source="loop_box" target="usr_box">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="640" y="340" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
