        <!-- Push mode -->
        <mxCell id="pTag" value="Push Mode" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=12;fontStyle=1;fontColor=#1565c0;" vertex="1" parent="1">
          <mxGeometry x="720" y="146" width="340" height="22" as="geometry" />
        </mxCell>
        <mxCell id="ge1" value="static void on_value_changed(data, size, ud)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;strokeWidth=1.2;fontSize=10;fontFamily=Courier New;fontStyle=1;fontColor=#0d47a1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="170" width="340" height="34" as="geometry" />
        </mxCell>
        <mxCell id="ge2" value="vlink_create_getter(url, &amp;amp;schema, &amp;amp;g, on_value_changed, ud)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;strokeWidth=1.2;fontSize=10;fontFamily=Courier New;fontStyle=1;fontColor=#0d47a1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="210" width="340" height="38" as="geometry" />
        </mxCell>
        <mxCell id="ge3" value="callback invoked on every change" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1976d2;strokeColor=#1565c0;strokeWidth=1.5;fontSize=12;fontFamily=Courier New;fontStyle=1;fontColor=#ffffff;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="254" width="340" height="40" as="geometry" />
        </mxCell>

        <!-- Poll mode -->
        <mxCell id="pTag2" value="Poll Mode" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=12;fontStyle=1;fontColor=#1565c0;" vertex="1" parent="1">
          <mxGeometry x="720" y="302" width="340" height="22" as="geometry" />
        </mxCell>
        <mxCell id="ge4" value="vlink_create_getter(url, &amp;amp;schema, &amp;amp;g, NULL, NULL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;strokeWidth=1.2;fontSize=10;fontFamily=Courier New;fontStyle=1;fontColor=#0d47a1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="326" width="340" height="38" as="geometry" />
        </mxCell>
        <mxCell id="ge5" value="uint8_t buf[256]; size_t sz = sizeof(buf);" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;strokeWidth=1.2;fontSize=10;fontFamily=Courier New;fontStyle=1;fontColor=#0d47a1;arcSize=10;" vertex="1" parent="1">
