        </mxCell>
        <mxCell id="ge6" value="vlink_get(g, buf, &amp;amp;sz)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1976d2;strokeColor=#1565c0;strokeWidth=1.5;fontSize=13;fontFamily=Courier New;fontStyle=1;fontColor=#ffffff;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="406" width="340" height="44" as="geometry" />
        </mxCell>
        <mxCell id="ge7" value="VLINK_RET_MEMORY_ERROR -&amp;gt; sz set to required size" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;strokeWidth=1.2;fontSize=10;fontFamily=Courier New;fontStyle=1;fontColor=#0d47a1;arcSize=10;dashed=1;" vertex="1" parent="1">
