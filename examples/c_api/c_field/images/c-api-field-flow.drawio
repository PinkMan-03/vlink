  <diagram id="c-api-field-flow" name="C API Field Flow">
    <mxGraphModel dx="1120" dy="640" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1120" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="C API Setter / Getter Field Flow" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=22;fontStyle=1;fontColor=#4a148c;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1040" height="32" as="geometry" />
        </mxCell>
        <mxCell id="sub" value="Latest-value field model  -  push (callback) or poll (vlink_get) with late-join semantics" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=13;fontStyle=2;fontColor=#6a1b9a;" vertex="1" parent="1">
          <mxGeometry x="40" y="54" width="1040" height="22" as="geometry" />
        </mxCell>

        <!-- Setter side - C API orange -->
        <mxCell id="setBg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ffcc80;strokeWidth=1.5;arcSize=8;shadow=1;gradientColor=#fff3e0;gradientDirection=north;" vertex="1" parent="1">
          <mxGeometry x="40" y="96" width="380" height="500" as="geometry" />
        </mxCell>
        <mxCell id="setBar" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ef6c00;strokeColor=none;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="40" y="96" width="380" height="8" as="geometry" />
        </mxCell>
        <mxCell id="setT" value="Setter  -  writer (latest value)" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=15;fontStyle=1;fontColor=#bf360c;" vertex="1" parent="1">
          <mxGeometry x="40" y="112" width="380" height="28" as="geometry" />
        </mxCell>

        <mxCell id="se1" value="vlink_schema_info_t schema = {&quot;text&quot;, VLINK_SCHEMA_RAW}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;strokeWidth=1.2;fontSize=10;fontFamily=Courier New;fontStyle=1;fontColor=#bf360c;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="150" width="340" height="40" as="geometry" />
        </mxCell>
        <mxCell id="se2" value="vlink_create_setter(url, &amp;amp;schema, &amp;amp;setter)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcc80;strokeColor=#e65100;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#bf360c;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="204" width="340" height="40" as="geometry" />
        </mxCell>
        <mxCell id="se3" value="vlink_set(setter, data, size)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ef6c00;strokeColor=#e65100;strokeWidth=1.5;fontSize=13;fontFamily=Courier New;fontStyle=1;fontColor=#ffffff;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="258" width="340" height="44" as="geometry" />
        </mxCell>
        <mxCell id="se4" value="loop: vlink_set(...)&#10;each call OVERWRITES prior value" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#bf360c;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="318" width="340" height="60" as="geometry" />
        </mxCell>
        <mxCell id="se5" value="vlink_destroy_setter(&amp;amp;setter)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcc80;strokeColor=#e65100;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#bf360c;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="394" width="340" height="40" as="geometry" />
        </mxCell>
        <mxCell id="seNote" value="Wraps Setter&amp;lt;Bytes&amp;gt;  -  one-and-only value slot per url" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=11;fontStyle=2;fontColor=#bf360c;" vertex="1" parent="1">
          <mxGeometry x="60" y="454" width="340" height="22" as="geometry" />
        </mxCell>

