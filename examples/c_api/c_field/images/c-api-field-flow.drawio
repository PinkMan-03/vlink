        <mxCell id="aw1" value="write" style="endArrow=classic;endFill=1;html=1;strokeWidth=2.5;strokeColor=#8e24aa;exitX=1;exitY=0.5;entryX=0;entryY=0.5;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;fontStyle=1;fontColor=#4a148c;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="se3" target="bagCur">
          <mxGeometry relative="1" as="geometry" />
