          <mxGeometry x="460" y="368" width="200" height="34" as="geometry" />
        </mxCell>
        <mxCell id="bagJoin" value="late-join: new getter reads current" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=10;fontStyle=2;fontColor=#4a148c;" vertex="1" parent="1">
          <mxGeometry x="440" y="412" width="240" height="22" as="geometry" />
