        <mxCell id="ge8" value="vlink_destroy_getter(&amp;amp;g)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#0d47a1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="498" width="340" height="36" as="geometry" />
        </mxCell>
        <mxCell id="geNote" value="msg_callback = NULL -&amp;gt; poll mode  -  no thread invocation" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=11;fontStyle=2;fontColor=#0d47a1;" vertex="1" parent="1">
          <mxGeometry x="720" y="544" width="340" height="22" as="geometry" />
