        <mxCell id="getT" value="Getter  -  reader (push or poll)" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=15;fontStyle=1;fontColor=#0d47a1;" vertex="1" parent="1">
          <mxGeometry x="700" y="112" width="380" height="28" as="geometry" />
