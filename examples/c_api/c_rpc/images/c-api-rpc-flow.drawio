          <mxGeometry x="40" y="112" width="480" height="28" as="geometry" />
        </mxCell>

        <mxCell id="c1" value="vlink_schema_info_t schema = {&quot;text&quot;, VLINK_SCHEMA_RAW}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#1b5e20;arcSize=10;" vertex="1" parent="1">
