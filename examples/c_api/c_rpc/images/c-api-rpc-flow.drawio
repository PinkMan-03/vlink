        </mxCell>
        <mxCell id="sub" value="Pure C method model  -  vlink_invoke / vlink_reply request-response over Bytes templates" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=13;fontStyle=2;fontColor=#2e7d32;" vertex="1" parent="1">
          <mxGeometry x="40" y="54" width="1040" height="22" as="geometry" />
        </mxCell>

