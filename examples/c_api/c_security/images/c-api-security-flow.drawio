          <mxGeometry x="20" y="92" width="1080" height="8" as="geometry" />
        </mxCell>
        <mxCell id="stdT" value="Standalone Security Roundtrip  -  transport-free encrypt / decrypt" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=15;fontStyle=1;fontColor=#7f0000;" vertex="1" parent="1">
          <mxGeometry x="20" y="108" width="1080" height="26" as="geometry" />
        </mxCell>

        <mxCell id="std1" value="vlink_security_config_t cfg;&#10;vlink_security_config_init(&amp;amp;cfg);" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#b71c1c;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#7f0000;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="146" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="std2" value="cfg.key = &quot;my-secret&quot;&#10;OR&#10;cfg.passphrase + pbkdf2_salt&#10;+ pbkdf2_iterations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ef9a9a;strokeColor=#b71c1c;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#7f0000;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="260" y="146" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="std3" value="vlink_security_handle_t sec =&#10;vlink_security_create(&amp;amp;cfg)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c62828;strokeColor=#b71c1c;strokeWidth=1.5;fontSize=12;fontFamily=Courier New;fontStyle=1;fontColor=#ffffff;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="146" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="std4" value="vlink_security_encrypt(sec, plain, n,&#10;&amp;amp;cipher, &amp;amp;cipher_size)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c62828;strokeColor=#b71c1c;strokeWidth=1.5;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#ffffff;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="146" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="std5" value="vlink_security_decrypt(sec, cipher, n,&#10;&amp;amp;plain, &amp;amp;plain_size)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ef9a9a;strokeColor=#b71c1c;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#7f0000;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="920" y="146" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="std6" value="vlink_security_free_buffer(cipher)&#10;vlink_security_free_buffer(plain)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#b71c1c;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#7f0000;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="160" y="236" width="280" height="42" as="geometry" />
        </mxCell>
        <mxCell id="std7" value="vlink_security_destroy(sec)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#b71c1c;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#7f0000;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="236" width="220" height="42" as="geometry" />
        </mxCell>
        <mxCell id="stdAlg" value="AES-128-GCM AEAD  -  envelope AAD  -  replay window  -  16B auth tag" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#b71c1c;strokeWidth=1.2;fontSize=11;fontStyle=2;fontColor=#7f0000;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="740" y="236" width="340" height="42" as="geometry" />
        </mxCell>
        <mxCell id="stdNote" value="encrypt/decrypt allocate output buffers internally  -  caller MUST release with vlink_security_free_buffer" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=11;fontStyle=2;fontColor=#7f0000;" vertex="1" parent="1">
