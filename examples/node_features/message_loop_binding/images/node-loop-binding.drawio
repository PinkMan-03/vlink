        <mxCell id="A_arr2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#616161;endArrow=classic;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="A_tr" target="A_cb" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="A_foot" value="Thread is not deterministic  -  concurrent callbacks possible" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=11;fontStyle=2;fontColor=#546e7a;" vertex="1" parent="1">
          <mxGeometry x="40" y="296" width="510" height="22" as="geometry" />
