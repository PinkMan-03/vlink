        <mxCell id="title" value="Node.attach(&amp;loop)  -  Routing Callbacks to a MessageLoop Thread" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=22;fontStyle=1;fontColor=#263238;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1080" height="32" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Without attach  -  callback runs on transport thread  &#183;  With attach  -  callback runs serialised on the loop thread" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=13;fontStyle=2;fontColor=#546e7a;" vertex="1" parent="1">
          <mxGeometry x="20" y="56" width="1080" height="22" as="geometry" />
        </mxCell>

        <mxCell id="caseA_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#bdbdbd;strokeWidth=1.5;arcSize=8;shadow=1;gradientColor=#eceff1;gradientDirection=north;" vertex="1" parent="1">
