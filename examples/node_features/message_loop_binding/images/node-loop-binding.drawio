        <mxCell id="B_arr2" value="&lt;b&gt;post_task&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#1976d2;endArrow=classic;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=11;fontStyle=1;fontColor=#0d47a1;labelBackgroundColor=#ffffff;" edge="1" source="B_tr" target="B_loop" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="B_foot" value="Single thread  -  deterministic order  -  no user mutex needed" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=11;fontStyle=2;fontColor=#0d47a1;" vertex="1" parent="1">
