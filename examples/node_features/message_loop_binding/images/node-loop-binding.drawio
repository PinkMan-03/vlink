        </mxCell>
        <mxCell id="caseB_t" value="Case B  -  attach(&amp;loop)  ( serialised on loop thread )" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=15;fontStyle=1;fontColor=#0d47a1;" vertex="1" parent="1">
