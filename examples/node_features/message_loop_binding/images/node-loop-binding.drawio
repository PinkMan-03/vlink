        </mxCell>
        <mxCell id="caseA_bar" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#616161;strokeColor=none;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="510" height="8" as="geometry" />
        </mxCell>
        <mxCell id="caseA_t" value="Case A  -  No attach  ( callback on transport thread )" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=15;fontStyle=1;fontColor=#212121;" vertex="1" parent="1">
          <mxGeometry x="40" y="116" width="510" height="28" as="geometry" />
        </mxCell>

        <mxCell id="A_pub" value="Publisher&lt;T&gt;.publish(msg)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;arcSize=10;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#0d47a1;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="220" height="48" as="geometry" />
        </mxCell>
        <mxCell id="A_tr" value="Transport internal thread&#10;( dds / shm / ddsc )" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bdbdbd;strokeColor=#424242;arcSize=10;strokeWidth=1.2;fontSize=11;fontStyle=1;fontColor=#212121;" vertex="1" parent="1">
          <mxGeometry x="60" y="226" width="220" height="56" as="geometry" />
        </mxCell>
        <mxCell id="A_cb" value="sub.listen(cb)&#10;cb runs on transport thread&#10;parallel  -  needs mutex" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eceff1;strokeColor=#424242;arcSize=10;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#212121;dashed=1;" vertex="1" parent="1">
