          <mxGeometry x="590" y="226" width="220" height="40" as="geometry" />
        </mxCell>
        <mxCell id="B_loop" value="MessageLoop  &quot;my_loop&quot;&#10;loop.async_run()&#10;sub.attach(&amp;loop)&#10;cb runs serialised here" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1976d2;strokeColor=#1565c0;arcSize=10;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
