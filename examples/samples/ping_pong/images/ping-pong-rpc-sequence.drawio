        </mxCell>
        <mxCell id="po4" value="// shm:// path:  const Bytes&amp; may&#10;//   alias shared memory  -  no copy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;arcSize=10;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=2;fontColor=#0d47a1;dashed=1;" vertex="1" parent="1">
