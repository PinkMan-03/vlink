        <mxCell id="po1" value="Subscriber&lt;Bytes&gt; sub(get_ping_url())&#10;Publisher&lt;Bytes&gt;  pub(get_pong_url())" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;arcSize=10;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#0d47a1;" vertex="1" parent="1">
          <mxGeometry x="720" y="202" width="340" height="56" as="geometry" />
        </mxCell>
        <mxCell id="po2" value="sub.listen([&amp;pub](const Bytes&amp; data){&#10;  pub.publish(data);   // echo back&#10;})" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1976d2;strokeColor=#1565c0;arcSize=10;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="720" y="284" width="340" height="84" as="geometry" />
        </mxCell>
        <mxCell id="po3" value="message_loop.run()&#10;// blocks until Ctrl+C" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;arcSize=10;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#0d47a1;" vertex="1" parent="1">
