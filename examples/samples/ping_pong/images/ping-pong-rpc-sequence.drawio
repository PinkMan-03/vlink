        <mxCell id="ping_t" value="Ping Process  ( sample_ping )" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=16;fontStyle=1;fontColor=#0d47a1;" vertex="1" parent="1">
          <mxGeometry x="40" y="116" width="380" height="28" as="geometry" />
        </mxCell>

        <mxCell id="p1" value="Bytes data = Bytes::create(test_size)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;arcSize=10;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#0d47a1;" vertex="1" parent="1">
          <mxGeometry x="60" y="156" width="340" height="36" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="Publisher&lt;Bytes&gt; pub(get_ping_url())&#10;Subscriber&lt;Bytes&gt; sub(get_pong_url())" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;arcSize=10;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#0d47a1;" vertex="1" parent="1">
          <mxGeometry x="60" y="202" width="340" height="56" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="start_stamp = steady_clock::now()&#10;( atomic timestamp )" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1976d2;strokeColor=#1565c0;arcSize=10;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="60" y="268" width="340" height="56" as="geometry" />
        </mxCell>
        <mxCell id="p4" value="pub.publish(data)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;arcSize=10;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#0d47a1;" vertex="1" parent="1">
          <mxGeometry x="60" y="334" width="340" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p5" value="Timer t; t.attach(&amp;message_loop)&#10;t.set_interval(1000)&#10;t.set_loop_count(Timer::kInfinite)&#10;t.start(send_func)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;arcSize=10;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#0d47a1;" vertex="1" parent="1">
          <mxGeometry x="60" y="384" width="340" height="84" as="geometry" />
        </mxCell>
        <mxCell id="p6" value="sub.listen([&amp;](const Bytes&amp;){&#10;  auto rtt = now() - start_stamp.load();&#10;  delay_ms = rtt.count() / 2000.0;&#10;})" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1976d2;strokeColor=#1565c0;arcSize=10;strokeWidth=1.2;fontSize=11;fontFamily=Courier New;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="60" y="478" width="340" height="100" as="geometry" />
        </mxCell>

