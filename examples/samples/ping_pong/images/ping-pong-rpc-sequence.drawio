        <mxCell id="title" value="Ping  -  Pong  -  Round-Trip Latency Measurement" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=22;fontStyle=1;fontColor=#0d47a1;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1080" height="32" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Two Publisher  /  Subscriber pairs over distinct topics  &#183;  payload reused via Bytes::create(N)  &#183;  delay = (t2 - t1) / 2" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=13;fontStyle=2;fontColor=#546e7a;" vertex="1" parent="1">
          <mxGeometry x="20" y="56" width="1080" height="22" as="geometry" />
        </mxCell>

        <mxCell id="ping_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#90caf9;strokeWidth=1.5;arcSize=8;shadow=1;gradientColor=#e3f2fd;gradientDirection=north;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="380" height="500" as="geometry" />
        </mxCell>
        <mxCell id="ping_bar" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1976d2;strokeColor=none;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="380" height="8" as="geometry" />
