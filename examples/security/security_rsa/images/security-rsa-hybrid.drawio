          <mxGeometry x="40" y="138" width="460" height="32" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="generate fresh 16B AES-128 session key (per-message)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c62828;strokeColor=#b71c1c;strokeWidth=1.5;fontSize=12;fontFamily=Courier New;fontStyle=1;fontColor=#ffffff;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="178" width="460" height="36" as="geometry" />
        </mxCell>
