        </mxCell>
        <mxCell id="sub" value="Fresh 16B AES-128 session key per message  -  RSA-OAEP-SHA256 wrap  -  AES-128-GCM payload  -  optional RSA-PSS-SHA256 sender authentication" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=12;fontStyle=2;fontColor=#c62828;" vertex="1" parent="1">
          <mxGeometry x="20" y="50" width="1080" height="22" as="geometry" />
