        <mxCell id="title" value="Security RSA-OAEP Hybrid  +  Optional RSA-PSS Signing" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=22;fontStyle=1;fontColor=#7f0000;" vertex="1" parent="1">
