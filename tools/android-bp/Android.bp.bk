// libvlink-defaults
cc_defaults {
    name: "libvlink-defaults",
    cppflags: [
        "-fexceptions",
        "-Wno-non-virtual-dtor",
        "-Wno-unknown-pragmas",
        "-Wno-implicit-fallthrough",
        "-Wno-unused-parameter",
    ],
    cpp_std: "c++17",
}

// libvlink
cc_prebuilt_library_shared {
    name: "libvlink",
    owner: "vlink",
    vendor_available: true,
    compile_multilib: "both",
    arch: {
        arm: {
            srcs: ["libs/arm/libvlink.so"],
        },
        arm64: {
            srcs: ["libs/arm64/libvlink.so"],
        },
    },
    export_include_dirs: [
        "include",
    ],
    shared_libs: [
        "liblog",
        "libcrypto",
        "libsqlite",
    ],
    check_elf_files: false,
    strip: {
        none: true,
    },
}

