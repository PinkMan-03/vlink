      {
        "source": "header.timestamp_ns",
        "target": "timestamp_ns"
      },
      {
        "source": "header.frame_id",
        "target": "frame_id",
        "default_value": "gnss"
      },
      {
        "source": "latitude",
        "target": "latitude"
      },
      {
        "source": "longitude",
        "target": "longitude"
      },
      {
        "source": "altitude",
        "target": "altitude"
      }
    ]
  },
