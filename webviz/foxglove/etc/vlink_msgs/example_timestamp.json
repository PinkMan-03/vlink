[
  {
    "_comment": "Example 1: GNSS with nanosecond sensor timestamp",
    "ser": "sensor.proto.GnssStamped",
    "schema": "foxglove.LocationFix",
    "encoding": "protobuf",
    "schema_encoding": "flatbuffers",
    "timestamp_field": "header.timestamp_ns",
    "timestamp_unit": "ns",
