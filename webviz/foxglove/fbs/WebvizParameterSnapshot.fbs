namespace vlink.webviz.foxglove.fbs;

enum ParameterType : ubyte {
  Unspecified = 0,
  ByteArray = 1,
  Float64 = 2,
  Float64Array = 3,
}

table ParameterEntry {
  name:string (id: 0);
  has_value:bool = false (id: 1);
  type:ParameterType = Unspecified (id: 2);
  json_value:string (id: 3);
}

table ParameterSnapshot {
  parameters:[ParameterEntry] (id: 0);
}

root_type ParameterSnapshot;
