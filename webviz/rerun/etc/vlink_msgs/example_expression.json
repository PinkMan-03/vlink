[
  {
    "_comment": "Example 1: DMS to decimal degrees (multi-variable linear)",
    "ser": "sensor.proto.GnssRaw",
    "archetype": "GeoPoints",
    "encoding": "protobuf",
    "field_mappings": [
      {
        "source": "latitude_deg",
        "target": "latitude",
        "expression": "latitude_deg + latitude_min / 60.0 + latitude_sec / 3600.0"
      },
      {
        "source": "longitude_deg",
        "target": "longitude",
        "expression": "longitude_deg + longitude_min / 60.0 + longitude_sec / 3600.0"
      }
    ]
  },
  {
    "_comment": "Example 2: Nested fields + direct quaternion pose",
    "ser": "nav.proto.Odometry",
    "archetype": "Transform3D",
    "encoding": "protobuf",
    "field_mappings": [
      {
        "source": "pose.position.x",
        "target": "position_x"
      },
      {
        "source": "pose.position.y",
        "target": "position_y"
      },
      {
        "source": "pose.position.z",
        "target": "position_z"
      },
      {
        "source": "pose.orientation",
        "target": "pose"
      }
    ]
  },
  {
    "_comment": "Example 3: Distance + velocity norm (sqrt, pow, multi-variable)",
    "ser": "nav.proto.VehicleState",
    "archetype": "Scalars",
    "encoding": "protobuf",
    "field_mappings": [
      {
        "source": "position.x",
        "target": "value",
        "_comment": "2D distance from origin",
        "expression": "sqrt(position.x^2 + position.y^2)"
      }
    ]
  },
  {
    "_comment": "Example 4: Conditional expression (if/else, clamp, unit conversion)",
    "ser": "control.proto.SteeringCmd",
    "archetype": "Scalars",
    "encoding": "protobuf",
    "field_mappings": [
      {
        "source": "steering_angle_rad",
        "target": "value",
        "_comment": "Radians to degrees, clamped to [-45, 45]",
        "expression": "clamp(-45.0, steering_angle_rad * 180.0 / pi, 45.0)"
      }
    ]
  },
  {
    "_comment": "Example 5: Euler normalization into translation axes",
    "ser": "sensor.proto.ImuProcessed",
    "archetype": "Transform3D",
    "encoding": "protobuf",
    "field_mappings": [
      {
        "source": "roll_rad",
        "target": "position_x",
        "_comment": "Roll normalized to [-180, 180] degrees",
        "expression": "atan2(sin(roll_rad), cos(roll_rad)) * 180.0 / pi"
      },
      {
        "source": "pitch_rad",
        "target": "position_y",
        "_comment": "Pitch clamped to [-90, 90] degrees",
        "expression": "clamp(-90.0, pitch_rad * 180.0 / pi, 90.0)"
      },
      {
        "source": "yaw_rad",
        "target": "position_z",
        "_comment": "Yaw in [0, 360) degrees",
        "expression": "((atan2(sin(yaw_rad), cos(yaw_rad)) * 180.0 / pi) + 360) % 360"
      }
    ]
  },
  {
    "_comment": "Example 6: Obstacle box transform with fallback heading",
    "ser": "perception.proto.ObstacleStamped",
    "archetype": "Boxes3D",
    "encoding": "protobuf",
    "field_mappings": [
      {
        "source": "obstacles",
        "target": "entities"
      },
      {
        "source": "center.x",
        "target": "entity_x"
      },
      {
        "source": "center.y",
        "target": "entity_y"
      },
      {
        "source": "center.z",
        "target": "entity_z",
        "_comment": "Lift center to half-height above ground plane",
        "expression": "center.z + height / 2.0"
      },
      {
        "source": "width",
        "target": "entity_width",
        "_comment": "Enforce minimum bounding box dimension",
        "expression": "max(width, 0.5)"
      },
      {
        "source": "length",
        "target": "entity_length",
        "expression": "max(length, 0.5)"
      },
      {
        "source": "height",
        "target": "entity_height",
        "expression": "max(height, 0.3)"
      },
      {
        "source": "heading",
        "target": "entity_heading",
        "_comment": "Radians to degrees; fallback to velocity heading if heading near zero",
        "expression": "if(abs(heading) > 0.001, heading * 180.0 / pi, atan2(velocity.y, velocity.x) * 180.0 / pi)"
      }
    ]
  },
  {
    "_comment": "Example 7: Simple lat/lon passthrough",
    "ser": "sensor.proto.GnssFix",
    "archetype": "GeoPoints",
    "encoding": "protobuf",
    "field_mappings": [
      {
        "source": "latitude",
        "target": "latitude"
      },
      {
        "source": "longitude",
        "target": "longitude"
      }
    ]
  }
]
